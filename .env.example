LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# LLM_BASE_URL=

# Optional: use a different provider/model only for the judge stage
# JUDGE_PROVIDER=openai
# JUDGE_MODEL=gpt-4o-mini
# JUDGE_API_KEY=your_api_key_here
# JUDGE_BASE_URL=

# Optional: override output file when running main.py
# BENCHMARK_OUTPUT=final_results.json

# Optional: OpenRouteService route distance validation
# ORS_API_KEY=your_openrouteservice_key_here
# ORS_PROFILE=foot-walking
# ORS_BASE_URL=https://api.openrouteservice.org
